@model IEnumerable<KhmerFestival.Models.Entities.DanhMuc>
@{ ViewBag.Title = "Danh muc"; }
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3">Danh mục lễ hội</h1>
    @Html.ActionLink("Thêm mới", "Create", null, new { @class = "btn btn-primary" })
</div>
<table class="table table-striped table-sm align-middle">
    <thead><tr><th>Tên danh mục</th><th>Số lễ hội</th><th></th></tr></thead>
    <tbody>
    @if (!Model.Any())
    {
        <tr><td colspan="3" class="text-center text-muted py-3">Không có dữ liệu</td></tr>
    }
    else
    {
        foreach (var item in Model)
        {
            <tr>
                <td>@item.TenDanhMuc</td>
                <td>@(item.LehHois == null ? 0 : item.LehHois.Count(x => !x.IsDeleted))</td>
                <td class="text-end">
                    @Html.ActionLink("Sửa", "Edit", new { id = item.Id }, new { @class = "btn btn-sm btn-outline-primary" })
                    @using (Html.BeginForm("Delete", "DanhMuc", new { id = item.Id }, FormMethod.Post, new { @class = "d-inline" })) { @Html.AntiForgeryToken()<button class="btn btn-sm btn-outline-danger">Xóa</button> }
                </td>
            </tr>
        }
    }
    </tbody>
</table>
