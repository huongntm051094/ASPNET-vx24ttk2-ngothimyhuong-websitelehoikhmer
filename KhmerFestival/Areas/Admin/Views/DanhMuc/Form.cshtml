@model KhmerFestival.Models.Entities.DanhMuc
@{ ViewBag.Title = Model.Id == 0 ? "Thêm danh mục" : "Sửa danh mục"; }
<h1 class="h3">@ViewBag.Title</h1>
@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(x => x.Id)
    <div class="mb-3">@Html.LabelFor(x => x.TenDanhMuc, new { @class = "form-label" })@Html.TextBoxFor(x => x.TenDanhMuc, new { @class = "form-control" })@Html.ValidationMessageFor(x => x.TenDanhMuc, "", new { @class = "text-danger" })</div>
    <div class="mb-3">@Html.LabelFor(x => x.MoTa, new { @class = "form-label" })@Html.TextAreaFor(x => x.MoTa, new { @class = "form-control", rows = 4 })</div>
    <button class="btn btn-primary">Lưu</button>
    @Html.ActionLink("Hủy", "Index", null, new { @class = "btn btn-link" })
}
