@model KhmerFestival.Models.Entities.LehHoi
@{ ViewBag.Title = "Quan ly anh"; }
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3">Ảnh lễ hội: @Model.TenLehHoi</h1>
    @Html.ActionLink("Quay lại", "Index", null, new { @class = "btn btn-outline-secondary" })
</div>
@using (Html.BeginForm("UploadImages", "LehHoi", new { id = Model.Id }, FormMethod.Post, new { enctype = "multipart/form-data", @class = "mb-4" }))
{
    @Html.AntiForgeryToken()
    <label class="form-label">Upload nhiều ảnh (.jpg/.png, tối đa 2MB mỗi ảnh)</label>
    <div class="input-group">
        <input class="form-control" type="file" name="images" accept=".jpg,.jpeg,.png" multiple />
        <button class="btn btn-primary">Upload</button>
    </div>
}
<div class="row g-3">
    @foreach (var image in Model.HinhAnhs.OrderByDescending(x => x.LaDaiDien).ThenByDescending(x => x.NgayTao))
    {
        <div class="col-md-3">
            <div class="card h-100">
                <img src="@Url.Content(image.DuongDan)" class="card-img-top" alt="@image.MoTa" />
                <div class="card-body">
                    @if (image.LaDaiDien) { <span class="badge text-bg-warning mb-2">Đại diện</span> }
                    <div class="d-flex gap-2">
                        @using (Html.BeginForm("SetCover", "LehHoi", new { id = image.Id }, FormMethod.Post)) { @Html.AntiForgeryToken()<button class="btn btn-sm btn-outline-primary">Đặt đại diện</button> }
                        @using (Html.BeginForm("DeleteImage", "LehHoi", new { id = image.Id }, FormMethod.Post)) { @Html.AntiForgeryToken()<button class="btn btn-sm btn-outline-danger">Xóa</button> }
                    </div>
                </div>
            </div>
        </div>
    }
</div>
