@model IEnumerable<KhmerFestival.Models.Entities.LehHoi>
@{ ViewBag.Title = "Le hoi"; }
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3">Quản lý lễ hội</h1>
    @Html.ActionLink("Thêm mới", "Create", null, new { @class = "btn btn-primary" })
</div>
@using (Html.BeginForm("Index", "LehHoi", FormMethod.Get, new { @class = "row g-2 mb-3" }))
{
    <div class="col-md-4"><input class="form-control" name="q" value="@ViewBag.Query" placeholder="Tìm tên lễ hội" /></div>
    <div class="col-md-4">@Html.DropDownList("danhMucId", null, "Tất cả danh mục", new { @class = "form-select" })</div>
    <div class="col-md-2"><button class="btn btn-outline-primary w-100">Lọc</button></div>
}
<table class="table table-striped table-sm align-middle">
    <thead><tr><th>Tên</th><th>Danh mục</th><th>Ngày bắt đầu</th><th>Trạng thái</th><th></th></tr></thead>
    <tbody>
    @if (!Model.Any())
    {
        <tr><td colspan="5" class="text-center text-muted py-3">Không có dữ liệu</td></tr>
    }
    else
    {
        foreach (var item in Model)
        {
            <tr>
                <td>@item.TenLehHoi</td>
                <td>@(item.DanhMuc == null ? "" : item.DanhMuc.TenDanhMuc)</td>
                <td>@(item.NgayBatDau.HasValue ? item.NgayBatDau.Value.ToString("dd/MM/yyyy") : "")</td>
                <td>@(item.IsDeleted ? "Đã xóa" : "Hiển thị")</td>
                <td class="text-end">
                    @Html.ActionLink("Chi tiết", "Details", new { id = item.Id }, new { @class = "btn btn-sm btn-outline-info" })
                    @Html.ActionLink("Sửa", "Edit", new { id = item.Id }, new { @class = "btn btn-sm btn-outline-primary" })
                    @Html.ActionLink("Ảnh", "Images", new { id = item.Id }, new { @class = "btn btn-sm btn-outline-secondary" })
                    @using (Html.BeginForm("Delete", "LehHoi", new { id = item.Id }, FormMethod.Post, new { @class = "d-inline" })) { @Html.AntiForgeryToken()<button class="btn btn-sm btn-outline-danger">Xóa mềm</button> }
                </td>
            </tr>
        }
    }
    </tbody>
</table>
