<!doctype html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewBag.Title - Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/Content/css/site.css" rel="stylesheet" />
</head>
<body>
    <div class="admin-shell">
        <aside class="admin-sidebar">
            <h1 class="h5 px-3 py-3">Admin</h1>
            @Html.ActionLink("Dashboard", "Index", "Dashboard", new { area = "Admin" }, new { @class = "admin-link" })
            @Html.ActionLink("Danh mục", "Index", "DanhMuc", new { area = "Admin" }, new { @class = "admin-link" })
            @Html.ActionLink("Lễ hội", "Index", "LehHoi", new { area = "Admin" }, new { @class = "admin-link" })
            @Html.ActionLink("Bài viết", "Index", "BaiViet", new { area = "Admin" }, new { @class = "admin-link" })
            @Html.ActionLink("Bình luận", "Index", "BinhLuan", new { area = "Admin" }, new { @class = "admin-link" })
            @Html.ActionLink("Tài khoản", "Index", "TaiKhoan", new { area = "Admin" }, new { @class = "admin-link" })
            @Html.ActionLink("Về website", "Index", "Home", new { area = "" }, new { @class = "admin-link" })
        </aside>
        <main class="admin-main">
            <header class="admin-topbar">
                <span>@(Session["HoTen"] ?? "Admin")</span>
                @Html.ActionLink("Đăng xuất", "Logout", "Account", new { area = "" }, new { @class = "btn btn-sm btn-outline-danger" })
            </header>
            <div class="p-4">
                @if (TempData["Success"] != null)
                {<div class="alert alert-success">@TempData["Success"]</div>}
                @if (TempData["Error"] != null)
                {<div class="alert alert-danger">@TempData["Error"]</div>}
                @RenderBody()
            </div>
        </main>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.tiny.cloud/1/no-api-key/tinymce/6/tinymce.min.js" referrerpolicy="origin"></script>
    <script>if (window.tinymce) tinymce.init({ selector: '.richtext', height: 320 });</script>
    <script>
        setTimeout(function () {
            var alerts = document.querySelectorAll('.alert');
            alerts.forEach(function (alert) {
                alert.style.transition = 'opacity 0.5s';
                alert.style.opacity = '0';
                setTimeout(function () { alert.remove(); }, 500);
            });
        }, 3000);
    </script>
</body>
</html>
