@model IEnumerable<KhmerFestival.Models.Entities.BaiViet>
@{ ViewBag.Title = "Bài viết"; }
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3">Quản lý bài viết</h1>
    @Html.ActionLink("Thêm mới", "Create", null, new { @class = "btn btn-primary" })
</div>
@using (Html.BeginForm("Index", "BaiViet", FormMethod.Get, new { @class = "row g-2 mb-3" }))
{
    <div class="col-md-4"><input class="form-control" name="q" value="@ViewBag.Query" placeholder="Tìm tiêu đề" /></div>
    <div class="col-md-2"><button class="btn btn-outline-primary w-100">Tìm</button></div>
}
<table class="table table-striped table-sm align-middle">
    <thead><tr><th>Tiêu đề</th><th>Ngày tạo</th><th></th></tr></thead>
    <tbody>
    @if (!Model.Any())
    {
        <tr><td colspan="3" class="text-center text-muted py-3">Không có dữ liệu</td></tr>
    }
    else
    {
        foreach (var item in Model)
        {
            <tr>
                <td>@item.TieuDe</td>
                <td>@item.NgayTao.ToString("dd/MM/yyyy")</td>
                <td class="text-end">
                    @Html.ActionLink("Chi tiết", "Details", new { id = item.Id }, new { @class = "btn btn-sm btn-outline-info" })
                    @Html.ActionLink("Sửa", "Edit", new { id = item.Id }, new { @class = "btn btn-sm btn-outline-primary" })
                    @using (Html.BeginForm("Delete", "BaiViet", new { id = item.Id }, FormMethod.Post, new { @class = "d-inline" })) { @Html.AntiForgeryToken()<button class="btn btn-sm btn-outline-danger">Xóa mềm</button> }
                </td>
            </tr>
        }
    }
    </tbody>
</table>
