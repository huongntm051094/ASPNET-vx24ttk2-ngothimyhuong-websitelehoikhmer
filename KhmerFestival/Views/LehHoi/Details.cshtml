@model KhmerFestival.Models.Entities.LehHoi
@{ ViewBag.Title = Model.TenLehHoi; var related = ViewBag.Related as IEnumerable<KhmerFestival.Models.Entities.LehHoi>; }
<article>
    <h1 class="h3">@Model.TenLehHoi</h1>
    <p class="text-muted">@Model.DiaDiem - @Model.TinhThanh | @Model.NgayBatDau.GetValueOrDefault().ToString("dd/MM/yyyy")</p>
    @if (!string.IsNullOrWhiteSpace(Model.AnhDaiDien)) { <img src="@Url.Content(Model.AnhDaiDien)" class="detail-img mb-3" alt="@Model.TenLehHoi" /> }
    <div class="lead">@System.Net.WebUtility.HtmlDecode(Model.TomTat)</div>
    <h2 class="h5 mt-4">Mô tả</h2>
    <div>@Html.Raw(Model.MoTa)</div>
    <h2 class="h5 mt-4">Ý nghĩa văn hóa</h2>
    <div>@Html.Raw(Model.YNghiaVanHoa)</div>
</article>
@if (Model.HinhAnhs.Any())
{
    <h2 class="h5 mt-4">Thư viện ảnh</h2>
    <div class="row g-2">@foreach (var img in Model.HinhAnhs) { <div class="col-6 col-md-3"><img class="gallery-img" src="@Url.Content(img.DuongDan)" alt="@img.MoTa" /></div> }</div>
}
@Html.Partial("_BinhLuanPartial", Model.BinhLuans)
@using (Html.BeginForm("TaoBinhLuan", "LehHoi", FormMethod.Post, new { @class = "mt-3" }))
{
    @Html.AntiForgeryToken()
    <input type="hidden" name="lehHoiId" value="@Model.Id" />
    <textarea class="form-control mb-2" name="noiDung" maxlength="500" placeholder="Nhập bình luận"></textarea>
    <button class="btn btn-primary">Gửi bình luận</button>
}
<h2 class="h5 mt-4">Lễ hội liên quan</h2>
<div class="row g-3">@foreach (var item in related ?? Enumerable.Empty<KhmerFestival.Models.Entities.LehHoi>()) { <div class="col-md-4">@Html.Partial("~/Views/LehHoi/_LehHoiCard.cshtml", item)</div> }</div>
