@model KhmerFestival.Models.Entities.BaiViet
@{ ViewBag.Title = Model.TieuDe; }
<article>
    <h1 class="h3">@Model.TieuDe</h1>
    <p class="text-muted">@Model.NgayTao.ToString("dd/MM/yyyy") - @(Model.NguoiTao == null ? "" : Model.NguoiTao.HoTen)</p>
    @if (!string.IsNullOrWhiteSpace(Model.AnhDaiDien)) { <img src="@Url.Content(Model.AnhDaiDien)" class="detail-img mb-3" alt="@Model.TieuDe" /> }
    <div>@Html.Raw(Model.NoiDung)</div>
</article>
@Html.Partial("_BinhLuanPartial", Model.BinhLuans)
@using (Html.BeginForm("TaoBinhLuan", "BaiViet", FormMethod.Post, new { @class = "mt-3" }))
{
    @Html.AntiForgeryToken()
    <input type="hidden" name="baiVietId" value="@Model.Id" />
    <textarea class="form-control mb-2" name="noiDung" maxlength="500" placeholder="Nhập bình luận"></textarea>
    <button class="btn btn-primary">Gửi bình luận</button>
}
