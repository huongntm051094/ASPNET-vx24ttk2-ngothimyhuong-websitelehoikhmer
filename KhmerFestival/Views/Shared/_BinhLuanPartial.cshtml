@model IEnumerable<KhmerFestival.Models.Entities.BinhLuan>
<div class="comments mt-4">
    <h3 class="h5">Bình luận</h3>
    @foreach (var item in Model.Where(x => x.TrangThai == "DaDuyet").OrderByDescending(x => x.NgayTao))
    {
        <div class="border rounded p-3 mb-2">
            <div class="fw-semibold">@item.NguoiDung.HoTen</div>
            <div class="text-muted small">@item.NgayTao.ToString("dd/MM/yyyy HH:mm")</div>
            <p class="mb-0">@item.NoiDung</p>
        </div>
    }
</div>
