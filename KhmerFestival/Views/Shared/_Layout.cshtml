<!doctype html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewBag.Title - Lễ hội Khmer</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400..800&family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/Content/css/site.css" rel="stylesheet" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-khmer sticky-top">
        <div class="container">
            @Html.ActionLink("Lễ hội Khmer", "Index", "Home", null, new { @class = "navbar-brand fw-bold" })
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"><span class="navbar-toggler-icon"></span></button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">@Html.ActionLink("Trang chủ", "Index", "Home", null, new { @class = "nav-link" })</li>
                    <li class="nav-item">@Html.ActionLink("Lễ hội", "Index", "LehHoi", null, new { @class = "nav-link" })</li>
                    <li class="nav-item">@Html.ActionLink("Bài viết", "Index", "BaiViet", null, new { @class = "nav-link" })</li>
                    <li class="nav-item">@Html.ActionLink("Giới thiệu", "About", "Home", null, new { @class = "nav-link" })</li>
                    <li class="nav-item">@Html.ActionLink("Liên hệ", "Index", "Contact", null, new { @class = "nav-link" })</li>
                    @if (User.IsInRole("Admin")) { <li class="nav-item">@Html.ActionLink("Admin", "Index", "Dashboard", new { area = "Admin" }, new { @class = "nav-link" })</li> }
                </ul>
                @using (Html.BeginForm("Index", "Search", FormMethod.Get, new { @class = "d-flex me-3", role = "search" }))
                {
                    <input class="form-control form-control-sm me-2" name="q" placeholder="Tìm kiếm" />
                    <button class="btn btn-warning btn-sm" type="submit">Tìm</button>
                }
                <div class="d-flex gap-2">
                    @if (User.Identity.IsAuthenticated)
                    {
                        @Html.ActionLink("Hồ sơ", "Profile", "Account", null, new { @class = "btn btn-outline-light btn-sm" })
                        @Html.ActionLink("Đăng xuất", "Logout", "Account", null, new { @class = "btn btn-light btn-sm" })
                    }
                    else
                    {
                        @Html.ActionLink("Đăng nhập", "Login", "Account", null, new { @class = "btn btn-light btn-sm" })
                    }
                </div>
            </div>
        </div>
    </nav>
    <main class="container py-4">
        @if (TempData["Success"] != null) { <div class="alert alert-success">@TempData["Success"]</div> }
        @if (TempData["Error"] != null) { <div class="alert alert-danger">@TempData["Error"]</div> }
        @RenderBody()
    </main>
    <footer class="border-top py-4 mt-5">
        <div class="container d-flex flex-wrap justify-content-between gap-3">
            <span>Website giới thiệu văn hóa và lễ hội người Khmer tại Việt Nam.</span>
            <span>Email: admin@khmer-lehoi.vn</span>
        </div>
    </footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@4.0.0/dist/jquery.validate.unobtrusive.min.js"></script>
    @RenderSection("scripts", required: false)
</body>
</html>
