@model KhmerFestival.Models.ViewModels.ForgotPasswordViewModel
@{ ViewBag.Title = "Quên mật khẩu"; }

<div class="row justify-content-center mt-4 mb-5">
    <div class="col-md-8 col-lg-5">
        <div class="card p-4 p-md-5">
            <div class="text-center mb-4">
                <h1 class="h3 fw-bold mb-2">Quên mật khẩu</h1>
                <p class="text-muted small">Nhập email của bạn để lấy lại mật khẩu.</p>
            </div>
            
            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()
                if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger py-2 small mb-3">
                        @Html.ValidationSummary(true, "")
                    </div>
                }
                
                <div class="mb-4">
                    @Html.LabelFor(x => x.Email, new { @class = "form-label fw-semibold" })
                    @Html.TextBoxFor(x => x.Email, new { @class = "form-control", type = "email", placeholder = "Email đã đăng ký" })
                    @Html.ValidationMessageFor(x => x.Email, "", new { @class = "text-danger small mt-1 d-block" })
                </div>
                
                <div class="mb-4">
                    @Html.LabelFor(x => x.MatKhauMoi, new { @class = "form-label fw-semibold" })
                    @Html.PasswordFor(x => x.MatKhauMoi, new { @class = "form-control", placeholder = "Mật khẩu mới (ít nhất 6 ký tự)" })
                    @Html.ValidationMessageFor(x => x.MatKhauMoi, "", new { @class = "text-danger small mt-1 d-block" })
                </div>
                
                <div class="mb-4">
                    @Html.LabelFor(x => x.XacNhanMatKhau, new { @class = "form-label fw-semibold" })
                    @Html.PasswordFor(x => x.XacNhanMatKhau, new { @class = "form-control", placeholder = "Nhập lại mật khẩu mới" })
                    @Html.ValidationMessageFor(x => x.XacNhanMatKhau, "", new { @class = "text-danger small mt-1 d-block" })
                </div>
                
                <button class="btn btn-warning w-100 fw-bold mt-2">Đặt lại mật khẩu</button>
                
                <div class="text-center mt-4">
                    <p class="small text-muted mb-0">@Html.ActionLink("Quay lại đăng nhập", "Login", null, new { @class = "text-muted text-decoration-underline" })</p>
                </div>
            }
        </div>
    </div>
</div>
