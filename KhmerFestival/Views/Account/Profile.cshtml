@model KhmerFestival.Models.ViewModels.ProfileViewModel
@{ ViewBag.Title = "Hồ sơ"; }
<h1 class="h3">Hồ sơ cá nhân</h1>
<dl class="row">
    <dt class="col-sm-2">Họ tên</dt><dd class="col-sm-10">@Model.HoTen</dd>
    <dt class="col-sm-2">Email</dt><dd class="col-sm-10">@Model.Email</dd>
    <dt class="col-sm-2">Ngày đăng ký</dt><dd class="col-sm-10">@Model.NgayTao</dd>
</dl>
@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
    <div class="mb-3">@Html.LabelFor(x => x.HoTen, new { @class = "form-label" })@Html.TextBoxFor(x => x.HoTen, new { @class = "form-control" })@Html.ValidationMessageFor(x => x.HoTen, "", new { @class = "text-danger" })</div>
    <hr />
    <h2 class="h5">Đổi mật khẩu</h2>
    <div class="mb-3">@Html.LabelFor(x => x.MatKhauCu, new { @class = "form-label" })@Html.PasswordFor(x => x.MatKhauCu, new { @class = "form-control" })@Html.ValidationMessageFor(x => x.MatKhauCu, "", new { @class = "text-danger" })</div>
    <div class="mb-3">@Html.LabelFor(x => x.MatKhauMoi, new { @class = "form-label" })@Html.PasswordFor(x => x.MatKhauMoi, new { @class = "form-control" })@Html.ValidationMessageFor(x => x.MatKhauMoi, "", new { @class = "text-danger" })</div>
    <div class="mb-3">@Html.LabelFor(x => x.XacNhanMatKhauMoi, new { @class = "form-label" })@Html.PasswordFor(x => x.XacNhanMatKhauMoi, new { @class = "form-control" })@Html.ValidationMessageFor(x => x.XacNhanMatKhauMoi, "", new { @class = "text-danger" })</div>
    <button class="btn btn-primary">Cập nhật</button>
}
