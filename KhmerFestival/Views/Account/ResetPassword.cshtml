@model KhmerFestival.Models.ViewModels.ResetPasswordViewModel
@{ ViewBag.Title = "Đặt lại mật khẩu"; }
<h1 class="h3">Đặt lại mật khẩu</h1>
@if (ViewBag.InvalidToken == true)
{
    <div class="alert alert-danger">Liên kết đặt lại mật khẩu không hợp lệ hoặc đã hết hạn. Vui lòng yêu cầu lại.</div>
}
else
{
    using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(x => x.Token)
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })
        <div class="mb-3">@Html.LabelFor(x => x.MatKhauMoi, new { @class = "form-label" })@Html.PasswordFor(x => x.MatKhauMoi, new { @class = "form-control" })@Html.ValidationMessageFor(x => x.MatKhauMoi, "", new { @class = "text-danger" })</div>
        <div class="mb-3">@Html.LabelFor(x => x.XacNhanMatKhau, new { @class = "form-label" })@Html.PasswordFor(x => x.XacNhanMatKhau, new { @class = "form-control" })@Html.ValidationMessageFor(x => x.XacNhanMatKhau, "", new { @class = "text-danger" })</div>
        <button class="btn btn-primary">Đặt lại mật khẩu</button>
    }
}
