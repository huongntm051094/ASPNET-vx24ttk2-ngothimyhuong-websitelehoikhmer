@model KhmerFestival.Models.ViewModels.RegisterViewModel
@{ ViewBag.Title = "Đăng ký"; }

<div class="row justify-content-center mt-4 mb-5">
    <div class="col-md-8 col-lg-5">
        <div class="card p-4 p-md-5">
            <div class="text-center mb-4">
                <h1 class="h3 fw-bold mb-2">Đăng ký</h1>
                <p class="text-muted small">Vui lòng điền thông tin để tạo tài khoản mới.</p>
            </div>
            
            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()
                if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger py-2 small mb-3">
                        @Html.ValidationSummary(true, "")
                    </div>
                }
                
                <div class="mb-4">
                    @Html.LabelFor(x => x.HoTen, new { @class = "form-label fw-semibold" })
                    @Html.TextBoxFor(x => x.HoTen, new { @class = "form-control", placeholder = "Họ và tên của bạn" })
                    @Html.ValidationMessageFor(x => x.HoTen, "", new { @class = "text-danger small mt-1 d-block" })
                </div>
                
                <div class="mb-4">
                    @Html.LabelFor(x => x.Email, new { @class = "form-label fw-semibold" })
                    @Html.TextBoxFor(x => x.Email, new { @class = "form-control", type = "email", placeholder = "Email của bạn" })
                    @Html.ValidationMessageFor(x => x.Email, "", new { @class = "text-danger small mt-1 d-block" })
                </div>
                
                <div class="mb-4">
                    @Html.LabelFor(x => x.MatKhau, new { @class = "form-label fw-semibold" })
                    @Html.PasswordFor(x => x.MatKhau, new { @class = "form-control", placeholder = "Mật khẩu (ít nhất 6 ký tự)" })
                    @Html.ValidationMessageFor(x => x.MatKhau, "", new { @class = "text-danger small mt-1 d-block" })
                </div>
                
                <div class="mb-4">
                    @Html.LabelFor(x => x.XacNhanMatKhau, new { @class = "form-label fw-semibold" })
                    @Html.PasswordFor(x => x.XacNhanMatKhau, new { @class = "form-control", placeholder = "Nhập lại mật khẩu" })
                    @Html.ValidationMessageFor(x => x.XacNhanMatKhau, "", new { @class = "text-danger small mt-1 d-block" })
                </div>
                
                <button class="btn btn-warning w-100 fw-bold mt-2">Đăng ký</button>
                
                <div class="text-center mt-4">
                    <p class="small text-muted mb-0">Đã có tài khoản? @Html.ActionLink("Đăng nhập ngay", "Login", null, new { @class = "text-warning fw-bold text-decoration-none" })</p>
                </div>
            }
        </div>
    </div>
</div>
