@model KhmerFestival.Models.ViewModels.LoginViewModel
@{ ViewBag.Title = "Đăng nhập"; }

<div class="row justify-content-center mt-4 mb-5">
    <div class="col-md-8 col-lg-5">
        <div class="card p-4 p-md-5">
            <div class="text-center mb-4">
                <h1 class="h3 fw-bold mb-2">Đăng nhập</h1>
                <p class="text-muted small">Chào mừng trở lại! Vui lòng đăng nhập để tiếp tục.</p>
            </div>
            
            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()
                @Html.HiddenFor(x => x.ReturnUrl)
                if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger py-2 small mb-3">
                        @Html.ValidationSummary(true, "")
                    </div>
                }
                
                <div class="mb-4">
                    @Html.LabelFor(x => x.Email, new { @class = "form-label fw-semibold" })
                    @Html.TextBoxFor(x => x.Email, new { @class = "form-control", type = "email", placeholder = "Email của bạn" })
                    @Html.ValidationMessageFor(x => x.Email, "", new { @class = "text-danger small mt-1 d-block" })
                </div>
                
                <div class="mb-4">
                    @Html.LabelFor(x => x.MatKhau, new { @class = "form-label fw-semibold" })
                    @Html.PasswordFor(x => x.MatKhau, new { @class = "form-control", placeholder = "Mật khẩu" })
                    @Html.ValidationMessageFor(x => x.MatKhau, "", new { @class = "text-danger small mt-1 d-block" })
                </div>
                
                <div class="d-flex justify-content-end mb-4">
                    @Html.ActionLink("Quên mật khẩu?", "ForgotPassword", null, new { @class = "text-decoration-none small text-danger fw-semibold" })
                </div>
                
                <button class="btn btn-warning w-100 fw-bold">Đăng nhập</button>
                
                <div class="text-center mt-4">
                    <p class="small text-muted mb-0">Chưa có tài khoản? @Html.ActionLink("Đăng ký ngay", "Register", null, new { @class = "text-warning fw-bold text-decoration-none" })</p>
                </div>
            }
        </div>
    </div>
</div>
